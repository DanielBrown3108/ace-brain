# Copy this file to .env.local and fill in values from your Supabase project.
# Settings -> API in the Supabase dashboard.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required ONLY for the Cal.com webhook (/api/webhooks/cal). The service role
# key bypasses RLS so the webhook can insert booking rows without auth. Treat
# this like a password — never expose it to the browser, never commit it.
SUPABASE_SERVICE_ROLE_KEY=

# Cal.com — leave the public vars blank until Peter's account is live.
# When unset, /tutoring shows a "Booking opens soon" placeholder.
NEXT_PUBLIC_CAL_USERNAME=
NEXT_PUBLIC_CAL_EVENT_SLUG=

# Optional: a shared secret you set in Cal.com webhook settings. Used to
# verify incoming webhook requests are really from Cal.com.
CAL_WEBHOOK_SECRET=

# Resend (transactional email). Free tier: 3000 emails/mo, 100/day.
# Without RESEND_API_KEY the server logs the email it would have sent
# but doesn't actually send.
RESEND_API_KEY=
# From line on every email. Use the resend.dev sandbox sender until
# you have a verified domain in Resend.
EMAIL_FROM=ACE Brain <onboarding@resend.dev>

# Used in email links so they point at the live site instead of localhost.
NEXT_PUBLIC_SITE_URL=https://ace-brain-seven.vercel.app
