# Copy this file to .env.local and fill in values from your Supabase project.
# Settings -> API in the Supabase dashboard.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cal.com booking page — leave both blank until Peter's account is live.
# When unset, /tutoring shows a "Booking opens soon" placeholder instead
# of an embed pointing at a Cal.com 404.
NEXT_PUBLIC_CAL_USERNAME=
NEXT_PUBLIC_CAL_EVENT_SLUG=
